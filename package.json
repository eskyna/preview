{
  "name": "eskyna-website",
  "private": true,
  "version": "1.0.0",
  "description": "Lint tooling for Hugo website",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:css && npm run lint:md",
    "lint:css": "stylelint \"static/css/**/*.css\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#public\"",
    "lint-and-format": "node bin/lint-and-format",
    "lint-and-format:check": "node bin/lint-and-format",
    "lint-and-format:fix": "node bin/lint-and-format --fix",
    "check:empty-hash-links": "bash ./bin/check-empty-hash-links",
    "seo-audit": "node bin/seo-audit",
    "seo-audit:static": "node bin/seo-audit ./static/outfits",
    "check:live-assets": "python3 bin/check-live-assets",
    "build": "./bin/build-production",
    "build:ci": "./bin/build-production --templateMetrics --templateMetricsHints",
    "images:convert": "./bin/convert-images",
    "images:convert:all": "./bin/convert-images .",
    "lhci": "lhci autorun",
    "lhci:healthcheck": "lhci healthcheck",
    "translation-sync": "node bin/translation-sync",
    "translation-sync:check": "node bin/translation-sync",
    "translation-sync:apply": "node bin/translation-sync --sync",
    "test:responsive": "playwright test tests/responsive.spec.js",
    "test:responsive:update": "playwright test tests/responsive.spec.js --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@lhci/cli": "^0.15.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1"
  }
}
